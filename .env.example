RUST_LOG=mysql_mcp=info

# JSON array of database configurations
# Each entry needs: name, host, port, user, password, database
# Optional: max_connections (default 5), query_timeout_secs (default 30)
MYSQL_DATABASES='[
  {"name": "db-local", "host": "host.docker.internal", "port": 3306, "user": "sail", "password": "password", "database": "db-local"},
  {"name": "db-dev", "host": "host.docker.internal", "port": 3307, "user": "dev", "password": "YOUR_DEV_PASSWORD", "database": "db-dev"},
  {"name": "db-prod", "host": "host.docker.internal", "port": 3308, "user": "prod", "password": "YOUR_PROD_PASSWORD", "database": "db-prod"}
]'
